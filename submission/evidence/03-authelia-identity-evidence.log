### Authelia access-control policy excerpt
access_control:
  default_policy: 'deny'
  rules:
    # Here we define our sites. Keep in mind if we had a domain, we would use the public domain
    # inplace of the *.local
    # Create a domain and be creative!
    # domain defines the site that you wish to protect with authelia
    # "policy: 'two_factor'" protects the target domain behind authelia's 2FA
    # OR
    # not protect
    # In this case you want to utilize 'bypass' to allow users to freely access your blog.
    # "policy: 'bypass'"

    - domain: 'auth.home.local'
      policy: 'bypass'
    - domain: 'blog.home.local'
      policy: 'bypass'
    - domain: 'admin.home.local'
      policy: 'two_factor'

session:

